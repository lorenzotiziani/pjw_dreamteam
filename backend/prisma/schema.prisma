generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// UTENTI E OPERATORI
// ─────────────────────────────────────────

model TUtente {
  id       Int      @id @default(autoincrement())
  nome     String
  cognome  String
  email    String   @unique
  pwd      String
  ruolo    Ruolo    @default(USER)
  creatoIl DateTime @default(now())
  isActive Boolean @default(true)
  
  emailVerified Boolean @default(false)
  emailVerificationToken String?
  emailVerificationExpires DateTime?

  prenotazioni  Prenotazione[]
  operaziones   Operazione[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String
  userId    Int
  expiresAt DateTime
  isRevoked Boolean? @default(false)
  createdAt DateTime

  user TUtente @relation(fields: [userId], references: [id])
}

enum Ruolo {
  OPERATORE
  USER
  ADMIN
}

// ─────────────────────────────────────────
// CATALOGO
// ─────────────────────────────────────────

model PuntoVendita {
  id        Int     @id @default(autoincrement())
  nome      String
  indirizzo String
  citta     String
  attivo    Boolean @default(true)

  prenotazioni Prenotazione[]
  stockBici    StockBici[]

  @@map("punti_vendita")
}

model TipoBici {
  id                  Int           @id @default(autoincrement())
  categoria           CategoriaBici
  motorizzazione      Tipo          @default(NORMALE)
  taglia              Taglia
  prezzoMezzaGiornata Decimal       @db.Decimal(8, 2)

  righePrenotazione RigaPrenotazione[]
  stockBici         StockBici[]

  @@map("tipi_bici")
}

enum CategoriaBici {
  CITY_BIKE
  MOUNTAIN_BIKE
  GRAVEL
  ROAD_BIKE
}

enum Tipo {
  NORMALE
  ELETTRICA
}

enum Taglia {
  S
  M
  L
  XL
}

model StockBici {
  id                   Int @id @default(autoincrement())
  puntoVenditaId       Int
  tipoBiciId           Int
  quantitaTotale       Int
  quantitaManutenzione Int @default(0)

  puntoVendita PuntoVendita @relation(fields: [puntoVenditaId], references: [id])
  tipoBici     TipoBici     @relation(fields: [tipoBiciId], references: [id])

  @@unique([puntoVenditaId, tipoBiciId])
  @@map("stock_bici")
}

model Accessorio {
  id     Int     @id @default(autoincrement())
  nome   String  @unique
  prezzo Decimal @db.Decimal(6, 2)

  righeAccessorio RigaAccessorio[]

  @@map("accessori")
}

model CoperturaAssicurativa {
  id          Int     @id @default(autoincrement())
  nome        String  @unique
  descrizione String
  prezzo      Decimal @db.Decimal(6, 2)

  righePrenotazione RigaPrenotazione[]

  @@map("coperture_assicurative")
}

// ─────────────────────────────────────────
// PRENOTAZIONI
// ─────────────────────────────────────────

model Prenotazione {
  id                Int               @id @default(autoincrement())
  utenteId          Int
  puntoVenditaId    Int
  dataRitiro        DateTime          @db.Date
  oraRitiro         DateTime          @db.Time()
  dataOraRiconsegna DateTime
  stato             StatoPrenotazione @default(IN_ATTESA)
  totale            Decimal           @db.Decimal(10, 2)
  creataIl          DateTime          @default(now())

  utente       TUtente            @relation(fields: [utenteId], references: [id])
  puntoVendita PuntoVendita       @relation(fields: [puntoVenditaId], references: [id])
  righe        RigaPrenotazione[]
  operazioni   Operazione[]

  @@map("prenotazioni")
}

enum StatoPrenotazione {
  IN_ATTESA
  CONFERMATA
  RITIRATA
  RESTITUITA
  CANCELLATA
}

model RigaPrenotazione {
  id             Int     @id @default(autoincrement())
  prenotazioneId Int
  tipoBiciId     Int
  coperturaId    Int?
  subtotale      Decimal @db.Decimal(8, 2)

  prenotazione Prenotazione           @relation(fields: [prenotazioneId], references: [id], onDelete: Cascade)
  tipoBici     TipoBici               @relation(fields: [tipoBiciId], references: [id])
  copertura    CoperturaAssicurativa? @relation(fields: [coperturaId], references: [id])
  accessori    RigaAccessorio[]

  @@map("righe_prenotazione")
}

model RigaAccessorio {
  id                 Int @id @default(autoincrement())
  rigaPrenotazioneId Int
  accessorioId       Int
  quantita           Int @default(1)

  rigaPrenotazione RigaPrenotazione @relation(fields: [rigaPrenotazioneId], references: [id], onDelete: Cascade)
  accessorio       Accessorio       @relation(fields: [accessorioId], references: [id])

  @@unique([rigaPrenotazioneId, accessorioId])
  @@map("righe_accessorio")
}

// ─────────────────────────────────────────
// OPERAZIONI DI BACKOFFICE
// ─────────────────────────────────────────

model Operazione {
  id             Int            @id @default(autoincrement())
  prenotazioneId Int
  utenteId       Int
  tipo           TipoOperazione
  eseguitaIl     DateTime       @default(now())
  note           String?

  prenotazione Prenotazione @relation(fields: [prenotazioneId], references: [id])
  utente       TUtente      @relation(fields: [utenteId], references: [id])

  @@map("operazioni")
}

enum TipoOperazione {
  RITIRO
  RICONSEGNA
  DANNO
  RITARDO
  MANUTENZIONE
}
